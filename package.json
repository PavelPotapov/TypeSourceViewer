{
  "name": "type-source-viewer",
  "version": "0.1.0",
  "description": "Extract TypeScript type definitions as strings at build time. Show any type in Storybook.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/integrations/vite-plugin.d.ts",
      "import": "./dist/integrations/vite-plugin.js"
    },
    "./cli": {
      "types": "./dist/integrations/cli.d.ts",
      "import": "./dist/integrations/cli.js"
    },
    "./storybook": {
      "types": "./dist/integrations/storybook/index.d.ts",
      "import": "./dist/integrations/storybook/index.js"
    },
    "./storybook/preset": {
      "import": "./dist/integrations/storybook/preset.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "release": "commit-and-tag-version"
  },
  "keywords": [
    "storybook",
    "typescript",
    "type",
    "documentation",
    "addon",
    "vite-plugin"
  ],
  "author": "Pavel Potapov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PavelPotapov/TypeSourceViewer"
  },
  "files": [
    "dist",
    "src/virtual-type-strings.d.ts",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/theming": "^8.6.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "storybook": "^8.6.18",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@storybook/blocks": ">=7.0.0",
    "react": ">=18.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@storybook/blocks": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "prism-react-renderer": "^2.4.1"
  }
}
